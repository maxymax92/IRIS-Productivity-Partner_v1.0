# Copy to .env.local and fill in your values.

# Required
ANTHROPIC_API_KEY=                        # console.anthropic.com → API Keys
NEXT_PUBLIC_SUPABASE_URL=                 # Supabase dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=     # Supabase dashboard → Settings → API → anon/public key
SUPABASE_SECRET_KEY=                      # Supabase dashboard → Settings → API → service_role key
NEXT_PUBLIC_SITE_URL=http://localhost:3000 # Your app's public URL
NEXTAUTH_URL=http://localhost:3000        # Same as above
AUTH_SECRET=                              # Run: openssl rand -base64 32
NEXTAUTH_SECRET=                          # Same value as AUTH_SECRET

# Optional — Google OAuth
GOOGLE_CLIENT_ID=                         # console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_SECRET=                     # Same place as above
GOOGLE_API_KEY=                           # console.cloud.google.com → Credentials → API Keys

# Optional — Push notifications
NEXT_PUBLIC_VAPID_PUBLIC_KEY=             # Generate with: npx web-push generate-vapid-keys
