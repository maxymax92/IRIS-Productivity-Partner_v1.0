{
  "name": "iris-v2",
  "version": "0.0.1",
  "private": true,
  "description": "AI productivity partner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxymax92/IRIS-Productivity-Partner_v1.0.git"
  },
  "homepage": "https://github.com/maxymax92/IRIS-Productivity-Partner_v1.0#readme",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "type": "module",
  "packageManager": "npm@10.9.4",
  "scripts": {
    "dev": "rm -rf supabase/next/.next && cd supabase/next && next dev --turbo -p 3000",
    "build": "cd supabase/next && next build && cp -r public .next/standalone/supabase/next/public && cp -r .next/static .next/standalone/supabase/next/.next/static",
    "start": "cd supabase/next/.next/standalone/supabase/next && HOSTNAME=0.0.0.0 node server.js",
    "lint": "eslint supabase/next --max-warnings 0",
    "lint:fix": "eslint supabase/next --fix",
    "check-types": "tsc -p supabase/next/tsconfig.json --noEmit",
    "typecheck": "tsc -p supabase/next/tsconfig.json --noEmit",
    "check-types:edge": "deno check --config supabase/functions/deno.json supabase/functions/*/index.ts",
    "lint:edge": "deno lint supabase/functions",
    "format:check": "cd supabase/next && prettier --check .",
    "gate:ci": "npm run format:check && npm run lint && npm run check-types && npm run check-types:edge && npm run lint:edge",
    "clean": "rm -rf node_modules .next .turbo supabase/next/node_modules supabase/next/.next",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:functions": "supabase functions serve",
    "test:user-settings": "cd supabase/next && npx tsx scripts/test-user-settings-persistence.ts",
    "test:memory-context": "cd supabase/next && npx tsx scripts/test-memory-context.ts"
  },
  "workspaces": [
    "supabase/next"
  ],
  "overrides": {
    "react-dom": "^19.2.4",
    "typescript": "6.0.0-beta"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  }
}
