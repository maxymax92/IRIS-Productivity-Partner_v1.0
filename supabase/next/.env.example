# =============================================================================
# Iris — Environment Variables
# =============================================================================
# The canonical .env.example is at the project root (../../.env.example).
# In production, supabase/next/.env.local symlinks to ../../.env.local.
#
# For local development:
#   cp ../../.env.example ../../.env.local
#   # Then fill in your values.
#
# See the root .env.example for descriptions of each variable.
# =============================================================================

# --- Anthropic (required) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# --- Site URL (required) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# --- Auth (required) ---
AUTH_SECRET=generate-a-random-32-char-string
NEXTAUTH_SECRET=generate-a-random-32-char-string

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_API_KEY=

# --- Push Notifications (optional) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Agent Configuration (optional) ---
# AGENT_MODEL=claude-sonnet-4-6
# TITLE_MODEL=claude-haiku-4-5
# STREAM_KEEPALIVE_MS=10000
# SIGNED_URL_EXPIRY_SECONDS=3600
# SESSION_VOLUME_PATH=
# NPM_CONFIG_PRODUCTION=false
